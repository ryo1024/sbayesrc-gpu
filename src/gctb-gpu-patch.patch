+        unsigned ai, bi;
+        __builtin_memcpy(&ai, &a, sizeof(ai));
+        __builtin_memcpy(&bi, &b, sizeof(bi));
+        bool an = ((ai & 0x7f800000u) == 0x7f800000u) && (ai & 0x7fffffu);
+        bool bn = ((bi & 0x7f800000u) == 0x7f800000u) && (bi & 0x7fffffu);
+        if (an && bn) return false;
+        if (an) return false;
+        if (bn) return true;
+        return a > b;
